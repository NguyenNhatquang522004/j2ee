# 🥗 FreshFood Environment Variables (Template)
# Copy this file to .env and fill in your actual values.

# Security
JWT_SECRET=your_jwt_secret_here

# Cloudinary (Media Storage)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Email Configuration
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587

# Meilisearch (Search Engine)
MEILI_MASTER_KEY=your_master_key

# Payment & Sentry (Optional)
SEPAY_TOKEN=your_sepay_token
SENTRY_DSN=

# Database (For Docker)
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/clean_food_db?createDatabaseIfNotExist=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
